rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocument() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return isAuthenticated() && userDocument().exists && userDocument().data.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isCashier() {
      return hasRole('caissier');
    }

    function isClient() {
      return hasRole('client');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validUserPayload() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.nom is string
        && request.resource.data.email is string
        && request.resource.data.role in ['client', 'admin', 'caissier']
        && request.resource.data.phone is string
        && request.resource.data.imageProfile is string
        && request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow create: if validUserPayload() && (isOwner(userId) || isAdmin());
      allow read: if isAdmin() || isOwner(userId);
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role)
        || isAdmin();
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        && request.resource.data.productId is string
        && request.resource.data.name is string
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.price is number
        && request.resource.data.stock is int
        && request.resource.data.imageUrl is string
        && request.resource.data.barcode is string
        && request.resource.data.qrCode is string
        && request.resource.data.createdAt is timestamp;
    }

    match /carts/{userId} {
      allow read, write, delete: if isOwner(userId);

      match /items/{itemId} {
        allow read, write, delete: if isOwner(userId)
          && request.resource.data.productId is string
          && request.resource.data.name is string
          && request.resource.data.quantity is int
          && request.resource.data.price is number
          && request.resource.data.imageUrl is string
          && request.resource.data.totalPrice is number;
      }
    }

    match /orders/{orderId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId == orderId
        && request.resource.data.products is list
        && request.resource.data.total is number
        && request.resource.data.status in ['en attente', 'validée', 'annulée', 'livrée']
        && request.resource.data.paymentMethod is string
        && request.resource.data.createdAt is timestamp;

      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /complaints/{complaintId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sujet is string
        && request.resource.data.message is string
        && request.resource.data.status in ['ouverte', 'en cours', 'résolue']
        && request.resource.data.adminResponse is string
        && request.resource.data.createdAt is timestamp;

      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow create: if (isCashier() || isAdmin())
        && request.resource.data.cashierId == request.auth.uid
        && request.resource.data.products is list
        && request.resource.data.total is number
        && request.resource.data.paymentType is string
        && request.resource.data.createdAt is timestamp;

      allow read: if isAdmin() || (isCashier() && resource.data.cashierId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
